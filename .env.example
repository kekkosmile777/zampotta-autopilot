# ===== Zampotta Autopilot — variabili d'ambiente =====
# Copia questo file in ".env" (in locale) oppure inserisci questi valori come GitHub Secrets.
# NON committare mai i valori reali.

# --- Generale ---
# Canali attivi separati da virgola: instagram,youtube,tiktok
ENABLED_CHANNELS=instagram,youtube
# Base pubblica dove i video sono raggiungibili (serve a Instagram/TikTok che vogliono un URL pubblico).
# Con GitHub si usa la URL raw del repo, es:
PUBLIC_MEDIA_BASE=https://raw.githubusercontent.com/<tuo-utente>/zampotta-autopilot/main/media

# --- Instagram (Meta Graph API) ---
IG_USER_ID=                 # ID dell'account Instagram Business
IG_ACCESS_TOKEN=            # token a lunga durata (60 giorni)
META_APP_ID=
META_APP_SECRET=

# --- YouTube (Data API v3) ---
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=

# --- TikTok (Content Posting API) ---
TIKTOK_ACCESS_TOKEN=
